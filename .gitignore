!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store

# Tooling
/coverage/
*.profraw
*.profdata
/.cache/

# Node (VSCode extension)
editors/vscode/node_modules/
editors/vscode/*.vsix
editors/vscode/out/

# Logs
*.log
